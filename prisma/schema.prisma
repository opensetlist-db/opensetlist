// schema.prisma — OpenSetlist
// Supports: anime/game music, J-POP, K-POP, C-POP
// Core v9 + Community v4
//
// Prisma 7 notes:
//   - datasource url/directUrl are in prisma.config.ts, NOT here
//   - generator uses provider = "prisma-client" (Prisma 7 style)
//   - PrismaClient initialized with PrismaPg adapter in src/lib/prisma.ts
//
// ID strategy:
//   BigInt @default(autoincrement()) — public-facing tables (appear in URLs)
//     Artist, Song, Event, EventSeries, SetlistItem
//   String @default(uuid())         — all other tables (junction, translation, community)
//
// Soft delete:
//   isDeleted + deletedAt on content tables: Artist, Song, Event, EventSeries,
//   SetlistItem, User. Junction/translation tables are hard-deleted when parent
//   is soft-deleted.

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  // url and directUrl live in prisma.config.ts — do not add them here
}

// ── ENUMS ─────────────────────────────────────────────

enum GroupType {
  franchise
  label
  agency
  series
}

enum GroupCategory {
  // animegame collapses the former separate `anime` + `game` values: the
  // user-facing filter chip already conflated them as 애니/게임, and no
  // domain logic distinguishes the two scenes. `others` is the explicit
  // catch-all for groups that don't fit any of the established
  // music-scene buckets — distinct from a NULL category, which means
  // "not yet classified" (data-hygiene state).
  animegame
  kpop
  jpop
  cpop
  others
}

enum ArtistType {
  solo
  group
  unit
}

enum StageIdentityType {
  character  // fictional anime/game character voiced by a VA
  persona    // real person performing as themselves (K-POP, J-POP)
}

enum EventSeriesType {
  concert_tour
  standalone
  festival
  fan_meeting
}

enum EventType {
  concert
  festival
  fan_meeting
  showcase
  virtual_live
}

enum EventStatus {
  scheduled // DB 기본값 — startTime 기반 자동 계산 대상
  ongoing // 관리자 override 또는 자동 (startTime ~ +12h)
  completed // 관리자 override 또는 자동 (startTime +12h 이후)
  cancelled // 관리자 override 전용
}

enum SetlistItemStageType {
  full_group
  unit
  solo
  special
}

enum SetlistItemStatus {
  rumoured   // fan prediction before event
  live       // currently being performed (real-time)
  confirmed  // verified after performance
}

enum SetlistItemPerformanceType {
  live_performance  // VA physically performs on stage
  virtual_live      // 3DCG character performs (Fes×LIVE)
  video_playback    // pre-recorded video played on screen
}

enum SetlistItemType {
  song      // normal song performance
  mc        // talk/MC segment
  video     // video playback (opening VTR etc.)
  interval  // intermission, costume change
}

enum SongArtistRole {
  primary
  featured
  cover
}

enum AlbumType {
  single
  album
  ep
  live_album
  soundtrack
}

enum ReactionType {
  waiting
  best
  surprise
  moved
}

enum CommentType {
  post     // BBS-style post — has title, written on Artist/Group/EventSeries board
  comment  // Inline reaction — no title, written on Song/Event/SetlistItem page
}

enum DictCategory {
  character_name   // 캐릭터명: 코즈에, 스페셜위크
  song_title       // 곡 제목: 하나무스비, Birdcage
  event_name       // 이벤트명: 블루파, 이차원 페스
  fandom_term      // 팬덤 용어: 직관, 최애, 성우
  abbreviation     // 약칭: 링크라, 하스노소라
  meme             // 밈/유행어: 뇨호호
  preserve         // do not translate — keep as-is
}

enum ReportTarget {
  comment      // Comment (type=comment or type=post)
  dict_entry   // TranslationDictionary entry
}

enum ReportReason {
  hate_speech     // 혐오 발언 (nationality, language, race discrimination)
  harassment      // 특정 유저 괴롭힘
  spam            // 스팸/광고
  misinformation  // 오정보 (잘못된 세트리스트 데이터 포함)
  copyright       // 저작권 침해
  bad_translation // 의도적 오번역 (dict_entry only)
  other
}

enum ReportStatus {
  pending    // 검토 대기
  reviewed   // 검토 완료, 조치 없음
  actioned   // 조치 완료 (content hidden / dict entry revoked)
  dismissed  // 기각 (허위 신고)
}

enum RoleType {
  superadmin  // site owner — all permissions
  admin       // global admin — can handle all reports, ban users
  board_mod   // local moderator — specific Artist or Group board only
  trusted     // trusted contributor — can approve dictionary entries
}

enum ScopeType {
  artist  // scoped to a specific Artist (and its sub-units)
  group   // scoped to a specific Group (and all its Artists)
}

// ── GROUP ─────────────────────────────────────────────
// Flat tagging layer above Artist.
// Represents franchises, labels, agencies, series.
// hasBoard: admin-controlled — only true groups become discussion boards.
// rollupGroupIds on Comment only includes groups where hasBoard = true.
// UUID: groups don't appear directly in public URLs.
model Group {
  id                  String             @id @default(uuid())
  // slug: required upsert key for CSV import. Aligns with the
  // Artist/Song/Event/EventSeries.slug @unique pattern even though
  // Group's id stays UUID (groups don't appear in public URLs, so the
  // slug is for import keying only).
  slug                String             @unique
  type                GroupType?
  category            GroupCategory?
  hasBoard            Boolean            @default(false)
  imageUrl            String?
  originalName        String
  originalShortName   String?
  originalDescription String?
  originalLanguage    String             @default("ja")
  createdAt           DateTime           @default(now())

  translations        GroupTranslation[]
  artistLinks         ArtistGroup[]
}

model GroupTranslation {
  id          String  @id @default(uuid())
  groupId     String
  locale      String  // "ko" | "ja" | "en" | "zh-CN"
  name        String
  shortName   String?
  description String?

  group       Group   @relation(fields: [groupId], references: [id])
  @@unique([groupId, locale])
  @@index([groupId])
}

// ── ARTIST ────────────────────────────────────────────
// Performing entity — a group, unit, solo artist, or band.
// parentArtistId handles sub-units (Cerise Bouquet → 蓮ノ空).
// hasBoard: most artists get a board by default.
// BigInt: appears in public URLs e.g. /artists/42
model Artist {
  id                BigInt              @id @default(autoincrement())
  slug              String              @unique
  parentArtistId    BigInt?
  type              ArtistType
  hasBoard          Boolean             @default(true)
  imageUrl          String?
  color             String?                    // unit badge color e.g. "#e91e8c" — nullable, falls back to zinc tokens
  // category: only meaningful for top-level artists (parentArtistId IS NULL)
  // that are NOT linked to any hasBoard=true Group. Drives the filter
  // chip + section badge for the synthetic "ungrouped" bucket on the
  // artists list page. When the artist IS linked to a hasBoard=true
  // Group, Group.category remains the source of truth and this field
  // is ignored. Nullable so unclassified artists land in the
  // "분류 미정" bucket (only visible under ?category=all) — distinct
  // from explicit `others`.
  category          GroupCategory?
  // isMainUnit: only meaningful for type=unit artists. Flags whether
  // this is a canonical/headline unit (e.g. DOLLCHESTRA, Mira-Cra Park!,
  // Cerise Bouquet) vs a derivative or event-specific sub-configuration.
  // The artists list page chip-renders only main units next to the
  // parent artist's row, since otherwise the chip strip becomes
  // unreadable for franchises with many incidental sub-units. Defaults
  // to false so the filter immediately collapses post-migration —
  // operator opts canonical units in rather than opting many out.
  // No-op for type=solo|group (the chip filter only runs over
  // sub-artists, which by construction are units).
  isMainUnit        Boolean             @default(false)
  originalName      String
  originalShortName String?
  originalBio       String?
  originalLanguage  String              @default("ja")
  isDeleted         Boolean             @default(false)
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())

  parentArtist   Artist?             @relation("ArtistChildren", fields: [parentArtistId], references: [id])
  subArtists     Artist[]            @relation("ArtistChildren")
  translations   ArtistTranslation[]
  groupLinks     ArtistGroup[]
  stageLinks     StageIdentityArtist[]
  songCredits    SongArtist[]
  eventSeries    EventSeries[]
  albums         AlbumArtist[]
  setlistItems   SetlistItemArtist[]

  @@index([parentArtistId])
  @@index([isDeleted])
}

model ArtistTranslation {
  id       String  @id @default(uuid())
  artistId BigInt
  locale   String
  name     String
  shortName String?
  bio      String?

  artist   Artist  @relation(fields: [artistId], references: [id])
  @@unique([artistId, locale])
  @@index([artistId])
}

// N:N between Artist and Group
model ArtistGroup {
  id       String @id @default(uuid())
  artistId BigInt
  groupId  String

  artist   Artist @relation(fields: [artistId], references: [id])
  group    Group  @relation(fields: [groupId], references: [id])
  @@unique([artistId, groupId])
  @@index([artistId])
  @@index([groupId])
}

// ── STAGE IDENTITY ────────────────────────────────────
// The name/persona fans identify performers by.
// type: "character" for anime idols (Kozue), "persona" for K-POP (Jin).
// A StageIdentity belongs to one or more Artists via StageIdentityArtist.
// UUID: not a primary search entity, referenced via Artist pages.
model StageIdentity {
  id                String                     @id @default(uuid())
  slug              String                     @unique
  type              StageIdentityType
  imageUrl          String?
  color             String?                    // personal color e.g. "#FF69B4" — nullable for K-POP
  originalName      String
  originalShortName String?
  originalLanguage  String                     @default("ja")
  createdAt         DateTime                   @default(now())

  translations    StageIdentityTranslation[]
  artistLinks     StageIdentityArtist[]
  voicedBy        RealPersonStageIdentity[]
  performances    SetlistItemMember[]
  eventPerformers EventPerformer[]
}

model StageIdentityTranslation {
  id              String        @id @default(uuid())
  stageIdentityId String
  locale          String
  name            String
  shortName       String?

  stageIdentity   StageIdentity @relation(fields: [stageIdentityId], references: [id])
  @@unique([stageIdentityId, locale])
  @@index([stageIdentityId])
}

// N:N between StageIdentity and Artist
// Megumi belongs to: 蓮ノ空, Mira-Cra Park!, KahoMegu♡Gelato
model StageIdentityArtist {
  id              String        @id @default(uuid())
  stageIdentityId String
  artistId        BigInt

  startDate       DateTime?     @db.Date
  endDate         DateTime?     @db.Date
  note            String?

  stageIdentity   StageIdentity @relation(fields: [stageIdentityId], references: [id])
  artist          Artist        @relation(fields: [artistId], references: [id])
  @@unique([stageIdentityId, artistId])
  @@index([stageIdentityId])
  @@index([artistId])
}

// ── REAL PERSON ───────────────────────────────────────
// The actual human performer.
// For K-POP: linked 1:1 to their StageIdentity.
// For anime: linked to the character they voice via RealPersonStageIdentity.
// UUID: referenced via StageIdentity, not a primary URL entity.
model RealPerson {
  id                String                    @id @default(uuid())
  slug              String                    @unique
  imageUrl          String?
  originalName      String
  originalShortName String?
  originalStageName String?
  originalLanguage  String                    @default("ja")
  createdAt         DateTime                  @default(now())

  translations    RealPersonTranslation[]
  stageIdentities RealPersonStageIdentity[]
  performances    SetlistItemMember[]
}

model RealPersonTranslation {
  id           String     @id @default(uuid())
  realPersonId String
  locale       String
  name         String
  shortName    String?    // short form fans use; separate dataset from `name`
  stageName    String?    // stage name if different from real name

  realPerson   RealPerson @relation(fields: [realPersonId], references: [id])
  @@unique([realPersonId, locale])
  @@index([realPersonId])
}

// Time-aware N:N between RealPerson and StageIdentity.
// Handles VA changes (startDate/endDate) and temporary covers (note).
model RealPersonStageIdentity {
  id              String        @id @default(uuid())
  realPersonId    String
  stageIdentityId String
  startDate       DateTime?     @db.Date
  endDate         DateTime?     @db.Date  // null = currently active
  note            String?       // "original VA" | "recast" | "one-day cover"

  realPerson      RealPerson    @relation(fields: [realPersonId], references: [id])
  stageIdentity   StageIdentity @relation(fields: [stageIdentityId], references: [id])
  @@index([realPersonId])
  @@index([stageIdentityId])
}

// ── EVENT SERIES ──────────────────────────────────────
// Groups related events under a named series.
// artistId: null for multi-artist festival series (Animelo, 이차원 페스).
// parentSeriesId: self-referencing for nested series (Animelo 2023 → Animelo brand).
// hasBoard: admin-controlled board visibility.
// BigInt: appears in public URLs e.g. /series/7
model EventSeries {
  id                  BigInt                   @id @default(autoincrement())
  slug                String                   @unique
  artistId            BigInt?
  parentSeriesId      BigInt?
  type                EventSeriesType
  organizerName       String?
  hasBoard            Boolean                  @default(false)
  imageUrl            String?
  originalName        String
  originalShortName   String?
  originalDescription String?
  originalLanguage    String                   @default("ja")
  isDeleted           Boolean                  @default(false)
  deletedAt           DateTime?
  createdAt           DateTime                 @default(now())

  artist         Artist?                  @relation(fields: [artistId], references: [id])
  parentSeries   EventSeries?             @relation("SeriesChildren", fields: [parentSeriesId], references: [id])
  childSeries    EventSeries[]            @relation("SeriesChildren")
  translations   EventSeriesTranslation[]
  events         Event[]

  @@index([artistId])
  @@index([parentSeriesId])
  @@index([isDeleted])
}

model EventSeriesTranslation {
  id            String      @id @default(uuid())
  eventSeriesId BigInt
  locale        String
  name          String
  shortName     String?
  description   String?

  eventSeries   EventSeries @relation(fields: [eventSeriesId], references: [id])
  @@unique([eventSeriesId, locale])
  @@index([eventSeriesId])
}

// ── EVENT ─────────────────────────────────────────────
// One event = one concert date. Multi-day shows are modeled as
// one Event per day sharing the same EventSeries.
// eventSeriesId: optional — null for truly standalone events.
// status: drives UI mode.
// BigInt: appears in public URLs e.g. /events/123
model Event {
  id                BigInt             @id @default(autoincrement())
  slug              String             @unique
  eventSeriesId     BigInt?
  type              EventType
  status            EventStatus        @default(scheduled)
  date              DateTime?          @db.Date
  startTime         DateTime           // UTC; used as lock time for wishlist
  country           String?            // ISO 3166 e.g. "KR" "JP" "US"
  posterUrl         String?
  originalName      String
  originalShortName String?
  originalCity      String?
  originalVenue     String?
  originalLanguage  String             @default("ja")
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())

  eventSeries   EventSeries?       @relation(fields: [eventSeriesId], references: [id])
  translations  EventTranslation[]
  setlistItems  SetlistItem[]
  performers    EventPerformer[]
  impressions   EventImpression[]
  wishes        SongWish[]

  @@index([eventSeriesId])
  @@index([date, status])
  @@index([isDeleted])
}

model EventTranslation {
  id        String @id @default(uuid())
  eventId   BigInt
  locale    String
  name      String
  shortName String?
  city      String?
  venue     String?

  event     Event  @relation(fields: [eventId], references: [id])
  @@unique([eventId, locale])
  @@index([eventId])
}

// Records all performers for an event — both regular and guests.
// Used as fallback for full group SetlistItems where performer_slugs is empty.
// isGuest=false → included in full group fallback
// isGuest=true  → excluded from fallback, explicit only
model EventPerformer {
  id              String        @id @default(uuid())
  eventId         BigInt
  stageIdentityId String

  isGuest         Boolean       @default(false)

  event           Event         @relation(fields: [eventId], references: [id])
  stageIdentity   StageIdentity @relation(fields: [stageIdentityId], references: [id])

  @@unique([eventId, stageIdentityId])
  @@index([eventId])
  @@index([stageIdentityId])
}

// ── SETLIST ITEM ──────────────────────────────────────
// One row = one performance slot in a concert.
// Songs linked via SetlistItemSong (supports medleys).
// Performers linked via SetlistItemMember.
// BigInt: appears in public URLs e.g. /events/123#item-456
model SetlistItem {
  id          BigInt               @id @default(autoincrement())
  eventId     BigInt
  position    Int
  isEncore    Boolean              @default(false)
  stageType   SetlistItemStageType @default(full_group)
  unitName    String?
  note        String?
  status          SetlistItemStatus           @default(confirmed)
  performanceType SetlistItemPerformanceType  @default(live_performance)
  type            SetlistItemType             @default(song)
  isDeleted       Boolean                     @default(false)
  deletedAt   DateTime?
  createdAt   DateTime             @default(now())

  event       Event                @relation(fields: [eventId], references: [id])
  artists     SetlistItemArtist[]
  songs       SetlistItemSong[]
  performers  SetlistItemMember[]
  reactions   SetlistItemReaction[]
  confirms    SetlistItemConfirm[]

  // Partial unique on (eventId, position) WHERE isDeleted = false lives in
  // prisma/post-deploy.sql — Prisma can't express partial uniques in schema.
  @@index([eventId])
  @@index([isDeleted])
}

model SetlistItemReaction {
  id            String   @id @default(uuid())
  setlistItemId BigInt
  reactionType  ReactionType
  createdAt     DateTime @default(now())
  // localStorage opensetlist_anon_id — nullable for legacy rows + clients
  // with localStorage disabled. Per-(setlistItemId, reactionType, anonId)
  // partial unique lives in prisma/post-deploy.sql since Prisma can't
  // declare partial uniques in schema. VarChar(64) mirrors
  // ANON_ID_MAX_LEN in the API routes — DB-level defense in depth.
  anonId        String?      @db.VarChar(64)

  setlistItem   SetlistItem @relation(fields: [setlistItemId], references: [id], onDelete: Cascade)

  @@index([setlistItemId, reactionType])
}

// Post-show one-line impressions ("한줄감상") per event.
// Append-only: edits supersede the prior row (supersededAt stamped) and
// insert a new immutable row. All versions share rootImpressionId; the
// head row sets rootImpressionId = id. supersededAt IS NULL identifies
// the current row of a chain.
// No login; dedup is client-side via localStorage, keyed by chain id.
// reportCount reaching REPORT_HIDE_THRESHOLD auto-sets isHidden on the
// current row only. Soft delete propagates across the whole chain.
model EventImpression {
  id               String    @id @default(uuid())
  eventId          BigInt
  rootImpressionId String
  content          String    @db.VarChar(200)
  locale           String    @default("ko")
  createdAt        DateTime  @default(now())
  supersededAt     DateTime?
  reportCount      Int       @default(0)
  isHidden         Boolean   @default(false)
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  // localStorage opensetlist_anon_id — same semantics as
  // SetlistItemReaction.anonId. Per-(rootImpressionId, anonId) partial
  // unique (head-only) in prisma/post-deploy.sql enforces one head row
  // per chain per anon. VarChar(64) mirrors ANON_ID_MAX_LEN in the API.
  anonId           String?   @db.VarChar(64)

  event            Event     @relation(fields: [eventId], references: [id])
  translations     ImpressionTranslation[]

  @@index([eventId, createdAt])
  @@index([rootImpressionId])
}

// LLM translation cache for EventImpression rows. Keyed by row id (not chain
// id) so each version of an edited impression caches independently — when an
// impression is edited, the new row gets a new id and the first viewer in
// any target locale pays the translator call again. Old versions' cached
// rows stay valid forever against the (now-superseded) source text.
model ImpressionTranslation {
  id             String   @id @default(uuid())
  impressionId   String
  sourceLocale   String
  targetLocale   String
  translatedText String   @db.Text
  createdAt      DateTime @default(now())

  impression     EventImpression @relation(fields: [impressionId], references: [id], onDelete: Cascade)

  @@unique([impressionId, sourceLocale, targetLocale])
  @@index([impressionId])
}

// N:N between SetlistItem and Artist — direct performing unit link
model SetlistItemArtist {
  id            String      @id @default(uuid())
  setlistItemId BigInt
  artistId      BigInt

  setlistItem   SetlistItem @relation(fields: [setlistItemId], references: [id])
  artist        Artist      @relation(fields: [artistId], references: [id])

  @@unique([setlistItemId, artistId])
  @@index([setlistItemId])
  @@index([artistId])
}

// N:N between SetlistItem and Song — supports medleys
model SetlistItemSong {
  id            String      @id @default(uuid())
  setlistItemId BigInt
  songId        BigInt
  order         Int?

  setlistItem   SetlistItem @relation(fields: [setlistItemId], references: [id])
  song          Song        @relation(fields: [songId], references: [id])
  @@unique([setlistItemId, songId])
  @@index([songId])
}

// Who performed each setlist item.
// stageIdentityId: always set — the character/persona fans identify.
// realPersonId: explicit performer — null only if genuinely unknown.
model SetlistItemMember {
  id              String        @id @default(uuid())
  setlistItemId   BigInt
  stageIdentityId String
  realPersonId    String?

  setlistItem     SetlistItem   @relation(fields: [setlistItemId], references: [id])
  stageIdentity   StageIdentity @relation(fields: [stageIdentityId], references: [id])
  realPerson      RealPerson?   @relation(fields: [realPersonId], references: [id])
  @@unique([setlistItemId, stageIdentityId])
  @@index([realPersonId])
}

// ── SONG ──────────────────────────────────────────────
// Artists linked via SongArtist (supports collaborations).
// baseVersionId: self-referencing for variants.
// variantLabel: "SAKURA Ver." | "104th Class Ver." | "acoustic ver."
// sourceNote: free text for edge cases. Null for 99%.
// BigInt: appears in public URLs e.g. /songs/789
model Song {
  id            BigInt            @id @default(autoincrement())
  slug          String            @unique
  baseVersionId BigInt?
  originalTitle    String
  originalLanguage String            @default("ja")
  variantLabel     String?
  releaseDate   DateTime?         @db.Date
  sourceNote    String?
  isDeleted     Boolean           @default(false)
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())

  baseVersion   Song?             @relation("SongVariants", fields: [baseVersionId], references: [id])
  variants      Song[]            @relation("SongVariants")
  artists       SongArtist[]
  translations  SongTranslation[]
  setlistItems  SetlistItemSong[]
  albumTracks   AlbumTrack[]
  wishes        SongWish[]

  @@index([baseVersionId])
  @@index([isDeleted])
}

// N:N between Song and Artist — supports collaborations
model SongArtist {
  id       String         @id @default(uuid())
  songId   BigInt
  artistId BigInt
  role     SongArtistRole @default(primary)

  song     Song           @relation(fields: [songId], references: [id])
  artist   Artist         @relation(fields: [artistId], references: [id])
  @@unique([songId, artistId])
  @@index([artistId])
}

model SongTranslation {
  id           String  @id @default(uuid())
  songId       BigInt
  locale       String
  title        String
  variantLabel String?

  song         Song    @relation(fields: [songId], references: [id])
  @@unique([songId, locale])
  @@index([songId])
}

// ── ALBUM ─────────────────────────────────────────────
// UUID: album pages are secondary — accessed via song or artist pages.
model Album {
  id               String             @id @default(uuid())
  slug             String             @unique
  type             AlbumType
  originalTitle    String
  originalLanguage String             @default("ja")
  releaseDate      DateTime?          @db.Date
  labelName        String?
  imageUrl         String?
  createdAt        DateTime           @default(now())

  translations AlbumTranslation[]
  tracks       AlbumTrack[]
  artists      AlbumArtist[]
}

model AlbumArtist {
  albumId  String
  artistId BigInt

  album    Album  @relation(fields: [albumId], references: [id])
  artist   Artist @relation(fields: [artistId], references: [id])

  @@unique([albumId, artistId])
  @@index([albumId])
  @@index([artistId])
}

model AlbumTranslation {
  id      String @id @default(uuid())
  albumId String
  locale  String
  title   String

  album   Album  @relation(fields: [albumId], references: [id])
  @@unique([albumId, locale])
  @@index([albumId])
}

// One song can appear on multiple albums (single, OST, best-of, live album)
model AlbumTrack {
  id          String @id @default(uuid())
  albumId     String
  songId      BigInt
  discNumber  Int    @default(1)
  trackNumber Int

  album       Album  @relation(fields: [albumId], references: [id])
  song        Song   @relation(fields: [songId], references: [id])
  @@unique([albumId, discNumber, trackNumber])
  @@index([songId])
}

// ── USER ──────────────────────────────────────────────
// UUID: user IDs should not be guessable or sequential.
model User {
  id                String        @id @default(uuid())
  email             String        @unique
  name              String
  avatarUrl         String?
  preferredLocale   String        @default("ko")
  knownLocales      String[]      @default(["ko"])
  autoTranslate     Boolean       @default(false)
  contributionCount Int           @default(0)
  isDeleted         Boolean       @default(false)
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())

  comments          Comment[]
  commentLikes      CommentLike[]
  commentEdits      CommentEdit[]
  roles             UserRole[]
  reports           Report[]
}

// ── COMMENT ───────────────────────────────────────────
// Posted-at: exactly one of the target fields is set.
// Boards available: setlistItem, song, event, eventSeries, artist, group.
// StageIdentity and RealPerson boards are excluded by design.
//
// Roll-up ancestry (server-computed at write time, immutable):
//   rollupSongIds[]        — songs of setlist item (medley support)
//   rollupEventIds[]       — leaf event + all ancestor events
//   rollupEventSeriesIds[] — direct series + all ancestor series
//   rollupArtistIds[]      — direct artists + all parent artists (any depth)
//   rollupGroupIds[]       — hasBoard=true groups only (admin-governed)
//   rollupCategories[]     — e.g. ["anime"] ["kpop"]
//
// All roll-up array fields use GIN indexes for efficient ANY() queries.
// BigInt IDs stored as strings in arrays (PostgreSQL TEXT[]).
//
// Governance rules:
//   - target fields are immutable after creation
//   - ancestry fields are immutable after creation
//   - content editable by owner only (logged in CommentEdit)
//   - isDeleted = true replaces hard delete (content set to "[deleted]")
model Comment {
  id            String               @id @default(uuid())
  userId        String
  parentId      String?

  type          CommentType          @default(comment)
  title         String?              // type=post only

  // posted at (exactly one set) — stored as strings for BigInt FK compatibility
  setlistItemId String?
  songId        String?
  eventId       String?
  eventSeriesId String?
  artistId      String?
  groupId       String?

  // user-selected tags for type=post (optional, enables rollup to tagged entities)
  taggedEventId String?
  taggedSongId  String?

  // optional song tag for live-viewing comments
  mentionedSongId String?

  // roll-up ancestry — server-computed, immutable after creation
  rollupSongIds         String[]
  rollupEventIds        String[]
  rollupEventSeriesIds  String[]
  rollupArtistIds       String[]
  rollupGroupIds        String[]
  rollupCategories      String[]

  content        String              @db.Text
  detectedLocale String              @default("ko")
  likeCount      Int                 @default(0)
  isDeleted      Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user           User                @relation(fields: [userId], references: [id])
  parent         Comment?            @relation("CommentReplies", fields: [parentId], references: [id])
  replies        Comment[]           @relation("CommentReplies")
  translations   CommentTranslation[]
  likes          CommentLike[]
  edits          CommentEdit[]

  @@index([userId, createdAt])
  @@index([createdAt, isDeleted])
  @@index([rollupSongIds], type: Gin)
  @@index([rollupEventIds], type: Gin)
  @@index([rollupEventSeriesIds], type: Gin)
  @@index([rollupArtistIds], type: Gin)
  @@index([rollupGroupIds], type: Gin)
  @@index([rollupCategories], type: Gin)
}

model CommentTranslation {
  id             String   @id @default(uuid())
  commentId      String
  targetLocale   String
  translatedText String   @db.Text
  createdAt      DateTime @default(now())

  comment        Comment  @relation(fields: [commentId], references: [id])
  @@unique([commentId, targetLocale])
  @@index([commentId])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   Comment  @relation(fields: [commentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([commentId, userId])
}

// Append-only audit trail for comment content edits
model CommentEdit {
  id         String   @id @default(uuid())
  commentId  String
  userId     String
  oldContent String   @db.Text
  newContent String   @db.Text
  editedAt   DateTime @default(now())

  comment    Comment  @relation(fields: [commentId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  @@index([commentId])
}

// ── USER ROLES ────────────────────────────────────────
// scopeType + scopeId = null → global role (superadmin, admin)
// scopeType = artist, scopeId = "42" → board_mod for that Artist only
// scopeType = group, scopeId = "uuid" → board_mod for all that Group's boards
model UserRole {
  id          String     @id @default(uuid())
  userId      String

  role        RoleType

  scopeType   ScopeType?
  scopeId     String?
  // Artist.id stored as String (BigInt serialized)
  // Group.id stored as String (UUID)
  // null for global roles (superadmin, admin)

  grantedBy   String     // userId of admin who granted this role
  grantedAt   DateTime   @default(now())
  expiresAt   DateTime?  // null = permanent
  note        String?    // e.g. "蓮ノ空 volunteer moderator"

  user        User       @relation(fields: [userId], references: [id])

  @@unique([userId, role, scopeType, scopeId])
  @@index([userId])
  @@index([scopeType, scopeId])
  @@index([role])
}

// ── TRANSLATION DICTIONARY ────────────────────────────
// Community-maintained overrides for translation API.
// Applied as pre-translation substitutions before calling Papago/DeepL.
model DictionaryTerm {
  id            String       @id @default(uuid())

  canonicalText String
  // Text sent to translation API after substitution.
  // For preserve=true: value doesn't matter (API not called).

  preserve      Boolean      @default(false)
  // true  → skip translation API, keep original text as-is
  // false → substitute canonicalText, then send to API

  category      DictCategory

  isApproved    Boolean      @default(false)
  // false → applied only for submitting user (trial period)
  // true  → applied for all users globally

  createdBy     String       // userId
  approvedBy    String?      // admin or trusted userId
  useCount      Int          @default(0)
  createdAt     DateTime     @default(now())

  surfaces      DictionaryTermSurface[]
  overrides     DictionaryOverride[]
}

model DictionaryTermSurface {
  id      String @id @default(uuid())
  termId  String
  locale  String
  // "ko" | "ja" | "en" | "zh-CN" | "zh-TW" | "*"

  text    String
  // The surface form in this locale.

  term    DictionaryTerm @relation(fields: [termId], references: [id])

  @@unique([termId, locale, text])
  @@index([text, locale])
  @@index([termId])
}

model DictionaryOverride {
  id           String @id @default(uuid())
  termId       String
  sourceLang   String
  targetLang   String
  overrideText String
  // Used instead of DictionaryTerm.canonicalText for this specific pair.

  createdBy    String
  createdAt    DateTime @default(now())

  term         DictionaryTerm @relation(fields: [termId], references: [id])

  @@unique([termId, sourceLang, targetLang])
  @@index([termId])
}

// ── REPORT ────────────────────────────────────────────
model Report {
  id          String       @id @default(uuid())
  reporterId  String

  targetType  ReportTarget
  targetId    String

  reason      ReportReason
  detail      String?      @db.Text

  status      ReportStatus @default(pending)

  assignedScope      String?    // scopeId of assigned board_mod
  assignedScopeType  ScopeType?

  resolvedBy  String?      // userId of admin/mod who handled it
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())

  reporter    User         @relation(fields: [reporterId], references: [id])

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([assignedScope, status])
}

// ── SONG WISH (Phase 1B engagement) ───────────────────
// Wishlist rows feeding the per-event TOP-3 aggregate UI.
// No anonId at 1B/1C — localStorage owns user-side dedup
// before POST. Server-side dedup arrives at Phase 2 with
// accounts. The (eventId, songId) index is for aggregation
// reads, not uniqueness.
model SongWish {
  id        String   @id @default(uuid())
  eventId   BigInt
  songId    BigInt
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id])
  song      Song     @relation(fields: [songId], references: [id])

  @@index([eventId, songId])
  @@index([eventId])
}

// ── SETLIST ITEM CONFIRM (Phase 1B engagement) ────────
// "I was there and saw this performed" votes.
// DB writes flag-gated by LAUNCH_FLAGS.confirmDbEnabled
// (see src/lib/launchFlags.ts) for the 5/23–5/24 Kobe
// events. Between 5/25 and 5/30, the flag and all gated
// branches are deleted — removal is the activation.
// At 1C the row carries no identifier — full identifier-
// bound dedup arrives at Phase 2. Operator monitor +
// override covers the bounded browser-cycling abuse risk
// in the meantime.
model SetlistItemConfirm {
  id            String   @id @default(uuid())
  setlistItemId BigInt
  createdAt     DateTime @default(now())

  setlistItem   SetlistItem @relation(fields: [setlistItemId], references: [id])

  @@index([setlistItemId])
}
